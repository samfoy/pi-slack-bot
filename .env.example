# Required
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_USER_ID=U...

# LLM (defaults shown)
PROVIDER=anthropic
MODEL=claude-sonnet-4-5
THINKING_LEVEL=off

# Sessions (defaults shown)
MAX_SESSIONS=10
SESSION_IDLE_TIMEOUT=3600
SESSION_DIR=~/.pi-slack-bot/sessions

# Streaming (defaults shown)
STREAM_THROTTLE_MS=3000
SLACK_MSG_LIMIT=3900

# cwd discovery (defaults shown)
WORKSPACE_DIRS=~/workplace

# Attach server (defaults shown)
ATTACH_PORT=3001
