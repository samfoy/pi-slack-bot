# Required
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_USER_ID=U...

# LLM (defaults shown)
PROVIDER=anthropic
MODEL=claude-opus-4-6-1m
# Comma-separated substrings to filter !model picker (empty = show all)
MODEL_ALLOWLIST=opus,sonnet
THINKING_LEVEL=off

# Sessions (defaults shown)
MAX_SESSIONS=10
SESSION_IDLE_TIMEOUT=3600
SESSION_DIR=~/.pi-slack-bot/sessions

# Streaming (defaults shown)
STREAM_THROTTLE_MS=3000
SLACK_MSG_LIMIT=3900

# Project discovery — comma-separated dirs to scan one level deep
WORKSPACE_DIRS=~/projects

# Node heap sizing (optional — run.sh applies a default of 768m)
# Override here if you need more headroom for many sessions, or less on a constrained host.
# Node 22 auto-sizes the V8 heap from the cgroup memory limit — under a 1G systemd
# MemoryMax this is only ~380 MB, which is too small for multiple active sessions.
# NODE_OPTIONS=--max-old-space-size=768
